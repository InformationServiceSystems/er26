id,schema,question,gold_sql,difficulty,category,tags
1,"CREATE TABLE Customers (CustomerID VARCHAR(5), CompanyName VARCHAR(40), ContactName VARCHAR(30), Country VARCHAR(15)); CREATE TABLE Orders (OrderID INT, CustomerID VARCHAR(5), OrderDate DATE, Freight DECIMAL(10,2));","Find all customers from Germany who have placed at least one order","SELECT DISTINCT c.CompanyName FROM Customers c JOIN Orders o ON c.CustomerID = o.CustomerID WHERE c.Country = 'Germany'",moderate,join_filter,"JOIN;WHERE;DISTINCT"
2,"CREATE TABLE Products (ProductID INT, ProductName VARCHAR(40), UnitPrice DECIMAL(10,2), UnitsInStock INT, Discontinued BOOLEAN); CREATE TABLE Categories (CategoryID INT, CategoryName VARCHAR(15));","List the average price of products in each category, only for categories with more than 5 products","SELECT cat.CategoryName, AVG(p.UnitPrice) AS AvgPrice FROM Products p JOIN Categories cat ON p.CategoryID = cat.CategoryID GROUP BY cat.CategoryName HAVING COUNT(*) > 5",complex,aggregation,"JOIN;GROUP BY;HAVING;AVG"
