@prefix : <http://example.org/northwind#> .
@prefix nw: <http://example.org/northwind#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# Northwind Full Domain — OWL 2 DL Ontology
# 11 classes, all relationships, business rules, ABox data
# ============================================================

<http://example.org/northwind> a owl:Ontology ;
    rdfs:label "Northwind Full Domain Ontology" ;
    rdfs:comment "Complete OWL 2 DL ontology for the Northwind food distribution domain covering customers, orders, products, employees, suppliers, shippers, categories, territories, and regions." .

# ============================================================
# Classes (11)
# ============================================================

nw:Customer a owl:Class ;
    rdfs:label "Customer" ;
    rdfs:comment "A company or individual that places purchase orders." .

nw:Order a owl:Class ;
    rdfs:label "Order" ;
    rdfs:comment "A purchase order placed by a customer, handled by an employee, and optionally shipped by a shipper." .

nw:OrderLine a owl:Class ;
    rdfs:label "OrderLine" ;
    rdfs:comment "A single line item within an order, referencing one product with quantity, price, and discount. Weak entity identified by its parent Order and referenced Product." .

nw:Product a owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "A product available for sale, belonging to a category and supplied by a supplier." .

nw:Category a owl:Class ;
    rdfs:label "Category" ;
    rdfs:comment "A grouping of related products (e.g., Beverages, Condiments)." .

nw:Supplier a owl:Class ;
    rdfs:label "Supplier" ;
    rdfs:comment "A company that supplies products to the distributor." .

nw:Employee a owl:Class ;
    rdfs:label "Employee" ;
    rdfs:comment "A staff member who handles customer orders and is assigned to sales territories." .

nw:Territory a owl:Class ;
    rdfs:label "Territory" ;
    rdfs:comment "A named sales territory within a region, assigned to one or more employees." .

nw:Region a owl:Class ;
    rdfs:label "Region" ;
    rdfs:comment "A broad geographic region containing one or more territories." .

nw:Shipper a owl:Class ;
    rdfs:label "Shipper" ;
    rdfs:comment "A shipping company used to deliver orders to customers." .

# ============================================================
# Disjointness — All 10 named classes are pairwise disjoint
# ============================================================

[] a owl:AllDisjointClasses ;
    owl:members ( nw:Customer nw:Order nw:OrderLine nw:Product
                  nw:Category nw:Supplier nw:Employee nw:Territory
                  nw:Region nw:Shipper ) .

# ============================================================
# Object Properties
# ============================================================

# --- Order --> Customer (N:1, total on Order) ---
nw:placedBy a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "placedBy" ;
    rdfs:comment "Relates an Order to the Customer who placed it." ;
    rdfs:domain nw:Order ;
    rdfs:range nw:Customer .

nw:placesOrder a owl:ObjectProperty ;
    rdfs:label "placesOrder" ;
    rdfs:comment "Inverse of placedBy. Relates a Customer to their Orders." ;
    owl:inverseOf nw:placedBy ;
    rdfs:domain nw:Customer ;
    rdfs:range nw:Order .

# --- Order --> Employee (N:1, total on Order) ---
nw:handledBy a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "handledBy" ;
    rdfs:comment "Relates an Order to the Employee responsible for processing it." ;
    rdfs:domain nw:Order ;
    rdfs:range nw:Employee .

nw:handlesOrder a owl:ObjectProperty ;
    rdfs:label "handlesOrder" ;
    rdfs:comment "Inverse of handledBy. Relates an Employee to Orders they handle." ;
    owl:inverseOf nw:handledBy ;
    rdfs:domain nw:Employee ;
    rdfs:range nw:Order .

# --- Order --> Shipper (N:1, partial on Order) ---
nw:shippedBy a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "shippedBy" ;
    rdfs:comment "Relates an Order to the Shipper that delivers it. Partial participation: unshipped orders have no shipper." ;
    rdfs:domain nw:Order ;
    rdfs:range nw:Shipper .

nw:shipsOrder a owl:ObjectProperty ;
    rdfs:label "shipsOrder" ;
    rdfs:comment "Inverse of shippedBy. Relates a Shipper to Orders it delivers." ;
    owl:inverseOf nw:shippedBy ;
    rdfs:domain nw:Shipper ;
    rdfs:range nw:Order .

# --- Order --> OrderLine (1:N, total on both) ---
nw:hasOrderLine a owl:ObjectProperty ;
    rdfs:label "hasOrderLine" ;
    rdfs:comment "Relates an Order to one of its OrderLines." ;
    rdfs:domain nw:Order ;
    rdfs:range nw:OrderLine .

nw:belongsToOrder a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "belongsToOrder" ;
    rdfs:comment "Inverse of hasOrderLine. Relates an OrderLine to its parent Order." ;
    owl:inverseOf nw:hasOrderLine ;
    rdfs:domain nw:OrderLine ;
    rdfs:range nw:Order .

# --- OrderLine --> Product (N:1, total on OrderLine) ---
nw:includesProduct a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "includesProduct" ;
    rdfs:comment "Relates an OrderLine to the single Product it references." ;
    rdfs:domain nw:OrderLine ;
    rdfs:range nw:Product .

nw:isIncludedIn a owl:ObjectProperty ;
    rdfs:label "isIncludedIn" ;
    rdfs:comment "Inverse of includesProduct. Relates a Product to the OrderLines referencing it." ;
    owl:inverseOf nw:includesProduct ;
    rdfs:domain nw:Product ;
    rdfs:range nw:OrderLine .

# --- Product --> Category (N:1, total on Product) ---
nw:belongsToCategory a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "belongsToCategory" ;
    rdfs:comment "Relates a Product to its Category." ;
    rdfs:domain nw:Product ;
    rdfs:range nw:Category .

nw:hasProduct a owl:ObjectProperty ;
    rdfs:label "hasProduct" ;
    rdfs:comment "Inverse of belongsToCategory. Relates a Category to its Products." ;
    owl:inverseOf nw:belongsToCategory ;
    rdfs:domain nw:Category ;
    rdfs:range nw:Product .

# --- Product --> Supplier (N:1, total on Product) ---
nw:suppliedBy a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "suppliedBy" ;
    rdfs:comment "Relates a Product to the Supplier that provides it." ;
    rdfs:domain nw:Product ;
    rdfs:range nw:Supplier .

nw:suppliesProduct a owl:ObjectProperty ;
    rdfs:label "suppliesProduct" ;
    rdfs:comment "Inverse of suppliedBy. Relates a Supplier to Products it supplies." ;
    owl:inverseOf nw:suppliedBy ;
    rdfs:domain nw:Supplier ;
    rdfs:range nw:Product .

# --- Employee --> Employee (N:1, partial, self-referencing) ---
nw:reportsTo a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "reportsTo" ;
    rdfs:comment "Relates an Employee to their direct manager. Partial participation: top-level employees have no manager. An employee cannot report to themselves." ;
    rdfs:domain nw:Employee ;
    rdfs:range nw:Employee .

nw:hasDirectReport a owl:ObjectProperty ;
    rdfs:label "hasDirectReport" ;
    rdfs:comment "Inverse of reportsTo. Relates a manager to their subordinates." ;
    owl:inverseOf nw:reportsTo ;
    rdfs:domain nw:Employee ;
    rdfs:range nw:Employee .

# --- Employee <--> Territory (M:N) ---
nw:servesTerritory a owl:ObjectProperty ;
    rdfs:label "servesTerritory" ;
    rdfs:comment "Relates an Employee to a Territory they are responsible for." ;
    rdfs:domain nw:Employee ;
    rdfs:range nw:Territory .

nw:servedByEmployee a owl:ObjectProperty ;
    rdfs:label "servedByEmployee" ;
    rdfs:comment "Inverse of servesTerritory. Relates a Territory to the Employees assigned to it." ;
    owl:inverseOf nw:servesTerritory ;
    rdfs:domain nw:Territory ;
    rdfs:range nw:Employee .

# --- Territory --> Region (N:1, total on Territory) ---
nw:inRegion a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "inRegion" ;
    rdfs:comment "Relates a Territory to the Region it belongs to. Each territory belongs to exactly one region." ;
    rdfs:domain nw:Territory ;
    rdfs:range nw:Region .

nw:hasTerritory a owl:ObjectProperty ;
    rdfs:label "hasTerritory" ;
    rdfs:comment "Inverse of inRegion. Relates a Region to its Territories." ;
    owl:inverseOf nw:inRegion ;
    rdfs:domain nw:Region ;
    rdfs:range nw:Territory .

# ============================================================
# Cardinality Restrictions
# ============================================================

# Order must be placed by exactly one Customer
nw:Order rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:placedBy ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Customer
] .

# Order must be handled by exactly one Employee
nw:Order rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:handledBy ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Employee
] .

# Order has at least one OrderLine
nw:Order rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:hasOrderLine ;
    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:OrderLine
] .

# Order shipped by at most one Shipper (partial: 0 or 1)
nw:Order rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:shippedBy ;
    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Shipper
] .

# OrderLine references exactly one Product
nw:OrderLine rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:includesProduct ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Product
] .

# OrderLine belongs to exactly one Order
nw:OrderLine rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:belongsToOrder ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Order
] .

# Product belongs to exactly one Category
nw:Product rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:belongsToCategory ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Category
] .

# Product supplied by exactly one Supplier
nw:Product rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:suppliedBy ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Supplier
] .

# Territory belongs to exactly one Region
nw:Territory rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty nw:inRegion ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass nw:Region
] .

# ============================================================
# IrreflexiveProperty — Employee cannot report to themselves
# ============================================================

nw:reportsTo a owl:IrreflexiveProperty .

# ============================================================
# Data Properties — Customer
# ============================================================

nw:customerID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "customerID" ;
    rdfs:comment "Unique five-character identifier for a customer." ;
    rdfs:domain nw:Customer ;
    rdfs:range xsd:string .

nw:companyName a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "companyName" ;
    rdfs:comment "Registered company name." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Shipper ) ] ;
    rdfs:range xsd:string .

nw:contactName a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "contactName" ;
    rdfs:comment "Name of the primary contact person." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier ) ] ;
    rdfs:range xsd:string .

nw:contactTitle a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "contactTitle" ;
    rdfs:comment "Job title of the primary contact person." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier ) ] ;
    rdfs:range xsd:string .

nw:address a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "address" ;
    rdfs:comment "Street address." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Employee ) ] ;
    rdfs:range xsd:string .

nw:city a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "city" ;
    rdfs:comment "City name." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Employee ) ] ;
    rdfs:range xsd:string .

nw:region a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "regionName" ;
    rdfs:comment "State or province name." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Employee ) ] ;
    rdfs:range xsd:string .

nw:postalCode a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "postalCode" ;
    rdfs:comment "Postal or ZIP code." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Employee ) ] ;
    rdfs:range xsd:string .

nw:country a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "country" ;
    rdfs:comment "Country name." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Employee ) ] ;
    rdfs:range xsd:string .

nw:phone a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "phone" ;
    rdfs:comment "Primary telephone number." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier nw:Shipper ) ] ;
    rdfs:range xsd:string .

nw:fax a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "fax" ;
    rdfs:comment "Fax number." ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( nw:Customer nw:Supplier ) ] ;
    rdfs:range xsd:string .

# ============================================================
# Data Properties — Order
# ============================================================

nw:orderID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "orderID" ;
    rdfs:comment "Unique numeric identifier for an order." ;
    rdfs:domain nw:Order ;
    rdfs:range xsd:integer .

nw:orderDate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "orderDate" ;
    rdfs:comment "Date on which the order was placed." ;
    rdfs:domain nw:Order ;
    rdfs:range xsd:dateTime .

nw:requiredDate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "requiredDate" ;
    rdfs:comment "Date by which the customer requires delivery." ;
    rdfs:domain nw:Order ;
    rdfs:range xsd:dateTime .

nw:shippedDate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "shippedDate" ;
    rdfs:comment "Date on which the order was shipped. Absent if not yet shipped." ;
    rdfs:domain nw:Order ;
    rdfs:range xsd:dateTime .

nw:freight a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "freight" ;
    rdfs:comment "Shipping cost for the order. Must be non-negative." ;
    rdfs:domain nw:Order ;
    rdfs:range xsd:decimal .

# ============================================================
# Data Properties — OrderLine
# ============================================================

nw:quantity a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "quantity" ;
    rdfs:comment "Number of units ordered. Must be a positive integer." ;
    rdfs:domain nw:OrderLine ;
    rdfs:range xsd:integer .

nw:olUnitPrice a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "unitPrice" ;
    rdfs:comment "Per-unit price charged for this line item. Must be non-negative." ;
    rdfs:domain nw:OrderLine ;
    rdfs:range xsd:decimal .

nw:discount a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "discount" ;
    rdfs:comment "Discount percentage applied to this line item, between 0 and 1 inclusive." ;
    rdfs:domain nw:OrderLine ;
    rdfs:range xsd:float .

# ============================================================
# Data Properties — Product
# ============================================================

nw:productID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "productID" ;
    rdfs:comment "Unique numeric identifier for a product." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:integer .

nw:productName a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "productName" ;
    rdfs:comment "Display name of the product." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:string .

nw:productUnitPrice a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "unitPrice" ;
    rdfs:comment "Current list price per unit for this product." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:decimal .

nw:unitsInStock a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "unitsInStock" ;
    rdfs:comment "Number of units currently in warehouse stock." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:integer .

nw:unitsOnOrder a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "unitsOnOrder" ;
    rdfs:comment "Number of units on order from the supplier." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:integer .

nw:reorderLevel a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "reorderLevel" ;
    rdfs:comment "Minimum stock level that triggers a reorder. If unitsInStock falls below this value, the product needs reordering." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:integer .

nw:discontinued a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "discontinued" ;
    rdfs:comment "True if the product has been discontinued. A discontinued product cannot appear on new orders." ;
    rdfs:domain nw:Product ;
    rdfs:range xsd:boolean .

# ============================================================
# Data Properties — Category
# ============================================================

nw:categoryID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "categoryID" ;
    rdfs:comment "Unique numeric identifier for a category." ;
    rdfs:domain nw:Category ;
    rdfs:range xsd:integer .

nw:categoryName a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "categoryName" ;
    rdfs:comment "Display name of the product category." ;
    rdfs:domain nw:Category ;
    rdfs:range xsd:string .

nw:description a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "description" ;
    rdfs:comment "Textual description of the category." ;
    rdfs:domain nw:Category ;
    rdfs:range xsd:string .

# ============================================================
# Data Properties — Supplier
# ============================================================

nw:supplierID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "supplierID" ;
    rdfs:comment "Unique numeric identifier for a supplier." ;
    rdfs:domain nw:Supplier ;
    rdfs:range xsd:integer .

nw:homePage a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "homePage" ;
    rdfs:comment "URL of the supplier's home page." ;
    rdfs:domain nw:Supplier ;
    rdfs:range xsd:string .

# ============================================================
# Data Properties — Employee
# ============================================================

nw:employeeID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "employeeID" ;
    rdfs:comment "Unique numeric identifier for an employee." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:integer .

nw:lastName a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "lastName" ;
    rdfs:comment "Employee's last name." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:string .

nw:firstName a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "firstName" ;
    rdfs:comment "Employee's first name." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:string .

nw:title a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "title" ;
    rdfs:comment "Employee's job title." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:string .

nw:birthDate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "birthDate" ;
    rdfs:comment "Employee's date of birth." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:dateTime .

nw:hireDate a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "hireDate" ;
    rdfs:comment "Date the employee was hired." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:dateTime .

nw:homePhone a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "homePhone" ;
    rdfs:comment "Employee's home telephone number." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:string .

nw:extension a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "extension" ;
    rdfs:comment "Employee's internal telephone extension." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:string .

nw:notes a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "notes" ;
    rdfs:comment "Free-text notes about the employee." ;
    rdfs:domain nw:Employee ;
    rdfs:range xsd:string .

# ============================================================
# Data Properties — Territory
# ============================================================

nw:territoryID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "territoryID" ;
    rdfs:comment "Unique identifier for a territory." ;
    rdfs:domain nw:Territory ;
    rdfs:range xsd:string .

nw:territoryDescription a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "territoryDescription" ;
    rdfs:comment "Descriptive name of the territory." ;
    rdfs:domain nw:Territory ;
    rdfs:range xsd:string .

# ============================================================
# Data Properties — Region
# ============================================================

nw:regionID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "regionID" ;
    rdfs:comment "Unique numeric identifier for a region." ;
    rdfs:domain nw:Region ;
    rdfs:range xsd:integer .

nw:regionDescription a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "regionDescription" ;
    rdfs:comment "Descriptive name of the region." ;
    rdfs:domain nw:Region ;
    rdfs:range xsd:string .

# ============================================================
# Data Properties — Shipper
# ============================================================

nw:shipperID a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "shipperID" ;
    rdfs:comment "Unique numeric identifier for a shipper." ;
    rdfs:domain nw:Shipper ;
    rdfs:range xsd:integer .

